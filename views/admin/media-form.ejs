<form action="<%= action %><%= action.includes('?') ? '&' : '?' %>_csrf=<%= csrfToken %>" method="post" class="admin-form">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <div class="admin-grid">
    <div class="admin-panel">
      <div class="panel-head">
        <h2><%= media.title %></h2>
        <span><%= media.media_type === 'movie' ? 'Movie' : 'Show' %> · TMDB #<%= media.tmdb_id %></span>
      </div>
      <div class="table-game mb-3">
        <img src="<%= media.poster_url || '/uploads/placeholder-cover.svg' %>" alt="">
        <div>
          <strong><%= media.title %></strong>
          <small><%= media.overview || 'No overview.' %></small>
        </div>
      </div>
      <div class="row g-3">
        <div class="col-md-6">
          <label class="form-check form-switch">
            <input class="form-check-input" type="checkbox" name="is_published" <%= media.is_published ? 'checked' : '' %>>
            <span class="form-check-label">Published</span>
          </label>
        </div>
        <div class="col-md-6">
          <label class="form-check form-switch">
            <input class="form-check-input" type="checkbox" name="is_featured" <%= media.is_featured ? 'checked' : '' %>>
            <span class="form-check-label">Featured</span>
          </label>
        </div>
      </div>
      <button class="btn btn-primary mt-3">Save</button>
    </div>

    <aside class="admin-panel">
      <div class="panel-head"><h2>TMDB Sync</h2></div>
      <p class="text-secondary">Refreshes title, poster, backdrop, overview, genres, seasons, and TMDB metadata.</p>
      <button class="btn btn-outline-primary w-100" formaction="/admin/media/<%= media.id %>/sync">Sync from TMDB</button>
      <hr>
      <a class="btn btn-outline-secondary w-100" href="/media/<%= media.media_type === 'movie' ? 'movie' : 'show' %>/<%= media.tmdb_id %>">View public page</a>
    </aside>
  </div>
</form>

<section class="admin-panel mt-4" id="download-links">
  <div class="panel-head">
    <h2><%= media.media_type === 'movie' ? 'Movie Links' : 'Show-Level Links' %></h2>
    <span>Use episode links for individual episodes</span>
  </div>
  <div class="link-manager">
    <% (media.media_download_links || []).sort((a, b) => (a.sort_order || 0) - (b.sort_order || 0)).forEach((link) => { %>
      <form action="/admin/media/<%= media.id %>/links/<%= link.id %>?_method=PUT" method="post" class="link-row media-link-row">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        <input class="form-control" name="label" value="<%= link.label %>" placeholder="Label">
        <input class="form-control" name="url" value="<%= link.url %>" placeholder="URL">
        <select class="form-select" name="source_type">
          <% ['direct','torrent','external','stream'].forEach((type) => { %>
            <option value="<%= type %>" <%= link.source_type === type ? 'selected' : '' %>><%= type %></option>
          <% }) %>
        </select>
        <input class="form-control" name="quality" value="<%= link.quality || '' %>" placeholder="1080p">
        <input class="form-control" name="file_size_mb" type="number" step="0.01" value="<%= link.file_size_mb || '' %>" placeholder="MB">
        <input class="form-control" name="sort_order" type="number" value="<%= link.sort_order || 0 %>">
        <label class="form-check"><input class="form-check-input" type="checkbox" name="is_active" <%= link.is_active ? 'checked' : '' %>> Active</label>
        <button class="btn btn-outline-primary btn-sm">Save</button>
        <button form="delete-media-link-<%= link.id %>" class="btn btn-outline-danger btn-sm" data-confirm="Delete this media link?">Delete</button>
      </form>
      <form id="delete-media-link-<%= link.id %>" action="/admin/media/<%= media.id %>/links/<%= link.id %>?_method=DELETE" method="post">
        <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      </form>
    <% }) %>
  </div>
  <form action="/admin/media/<%= media.id %>/links" method="post" class="link-row media-link-row new-link mt-3">
    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
    <input class="form-control" name="label" placeholder="Main link" required>
    <input class="form-control" name="url" placeholder="https://..." required>
    <select class="form-select" name="source_type">
      <option value="external">external</option>
      <option value="stream">stream</option>
      <option value="direct">direct</option>
      <option value="torrent">torrent</option>
    </select>
    <input class="form-control" name="quality" placeholder="1080p">
    <input class="form-control" name="file_size_mb" type="number" step="0.01" placeholder="MB">
    <input class="form-control" name="sort_order" type="number" value="0">
    <label class="form-check"><input class="form-check-input" type="checkbox" name="is_active" checked> Active</label>
    <button class="btn btn-primary btn-sm">Add Link</button>
  </form>
</section>

<% if (media.media_type === 'show') { %>
  <section class="admin-panel mt-4" id="seasons">
    <div class="panel-head">
      <h2>Seasons</h2>
      <span>Sync seasons to create episode records</span>
    </div>
    <div class="season-admin-list">
      <% seasons.forEach((season) => { %>
        <div class="season-admin-row">
          <strong><%= season.name || `Season ${season.season_number}` %></strong>
          <span><%= season.episode_count || 0 %> episodes</span>
          <form action="/admin/media/<%= media.id %>/seasons/<%= season.season_number %>/sync" method="post">
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button class="btn btn-sm btn-outline-primary">Sync episodes</button>
          </form>
          <a class="btn btn-sm btn-primary" href="/admin/media/<%= media.id %>/seasons/<%= season.season_number %>/episodes">Manage episode links</a>
          <a class="btn btn-sm btn-outline-secondary" href="/media/show/<%= media.tmdb_id %>/season/<%= season.season_number %>">View</a>
        </div>
      <% }) %>
    </div>
  </section>
<% } %>
