<div class="admin-actions">
  <form action="/admin/games" method="get" class="admin-search">
    <input class="form-control" name="q" value="<%= query.q || '' %>" placeholder="Search games">
    <select class="form-select" name="status">
      <option value="">All statuses</option>
      <option value="published" <%= query.status === 'published' ? 'selected' : '' %>>Published</option>
      <option value="draft" <%= query.status === 'draft' ? 'selected' : '' %>>Draft</option>
    </select>
    <input type="hidden" name="perPage" value="<%= perPage %>">
    <button class="btn btn-primary">Filter</button>
  </form>
  <a class="btn btn-primary" href="/admin/games/new"><i class="bi bi-plus-lg"></i> Add Game</a>
</div>

<div class="admin-panel">
  <table class="table table-hover align-middle admin-table" data-datatable>
    <thead>
      <tr>
        <th>Game</th>
        <th>Platforms</th>
        <th>Downloads</th>
        <th>Status</th>
        <th>Featured</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% games.forEach((game) => { %>
        <tr>
          <td>
            <div class="table-game">
              <img src="<%= game.cover_image_url || '/uploads/placeholder-cover.svg' %>" alt="">
              <div><strong><%= game.title %></strong><small><%= game.slug %></small></div>
            </div>
          </td>
          <td><%= (game.platform || []).join(', ') %></td>
          <td><%= Number(game.download_count || 0).toLocaleString() %></td>
          <td><span class="status-pill <%= game.is_published ? 'published' : 'draft' %>"><%= game.is_published ? 'Published' : 'Draft' %></span></td>
          <td><%= game.is_featured ? 'Yes' : 'No' %></td>
          <td class="text-end">
            <a class="btn btn-sm btn-outline-primary" href="/admin/games/<%= game.id %>/edit">Edit</a>
            <form class="d-inline" action="/admin/games/<%= game.id %>?_method=DELETE" method="post" data-confirm="Unpublish this game?">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button class="btn btn-sm btn-outline-danger">Unpublish</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>

<%- include('_pagination', { basePath: '/admin/games', id: 'games-per-page', query, page, totalPages, total, perPage }) %>
