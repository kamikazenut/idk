<form action="<%= action %><%= action.includes('?') ? '&' : '?' %>_csrf=<%= csrfToken %>" method="post" enctype="multipart/form-data" class="admin-form">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <div class="admin-grid">
    <div class="admin-panel">
      <div class="panel-head">
        <h2>Game Details</h2>
        <span><%= game ? 'Editing' : 'New game' %></span>
      </div>
      <div class="row g-3">
        <div class="col-md-8">
          <label class="form-label">Title</label>
          <input class="form-control" name="title" required value="<%= game?.title || '' %>">
        </div>
        <div class="col-md-4">
          <label class="form-label">Slug</label>
          <input class="form-control" name="slug" value="<%= game?.slug || '' %>">
        </div>
        <div class="col-12">
          <label class="form-label">Short Description</label>
          <input class="form-control" name="short_description" maxlength="280" value="<%= game?.short_description || '' %>">
        </div>
        <div class="col-12">
          <label class="form-label">Full Description</label>
          <textarea class="form-control" name="description" rows="8"><%= game?.description || '' %></textarea>
        </div>
        <div class="col-md-6">
          <label class="form-label">Genres</label>
          <input class="form-control" name="genre" value="<%= (game?.genre || []).join(', ') %>" placeholder="Action, Puzzle, RPG">
        </div>
        <div class="col-md-6">
          <label class="form-label">Platforms</label>
          <input class="form-control" name="platform" value="<%= (game?.platform || []).join(', ') %>" placeholder="Windows, DOS, Linux, Browser">
        </div>
        <div class="col-md-4">
          <label class="form-label">Release Year</label>
          <input class="form-control" name="release_year" type="number" min="1950" max="2100" value="<%= game?.release_year || '' %>">
        </div>
        <div class="col-md-4">
          <label class="form-label">Developer</label>
          <input class="form-control" name="developer" value="<%= game?.developer || '' %>">
        </div>
        <div class="col-md-4">
          <label class="form-label">Publisher</label>
          <input class="form-control" name="publisher" value="<%= game?.publisher || '' %>">
        </div>
        <div class="col-12">
          <label class="form-label">System Requirements</label>
          <textarea class="form-control" name="system_requirements" rows="4"><%= game?.system_requirements || '' %></textarea>
        </div>
      </div>
    </div>

    <aside class="admin-panel">
      <div class="panel-head"><h2>Publishing</h2></div>
      <div class="form-check form-switch">
        <input class="form-check-input" type="checkbox" role="switch" name="is_published" id="isPublished" <%= game?.is_published || !game ? 'checked' : '' %>>
        <label class="form-check-label" for="isPublished">Published</label>
      </div>
      <div class="form-check form-switch mt-2">
        <input class="form-check-input" type="checkbox" role="switch" name="is_featured" id="isFeatured" <%= game?.is_featured ? 'checked' : '' %>>
        <label class="form-check-label" for="isFeatured">Featured</label>
      </div>
      <hr>
      <label class="form-label">Cover URL</label>
      <input class="form-control" name="cover_image_url" value="<%= game?.cover_image_url || '' %>">
      <label class="form-label mt-3">Upload Cover</label>
      <input class="form-control" type="file" name="cover" accept="image/*">
      <label class="form-label mt-3">Banner URL</label>
      <input class="form-control" name="banner_image_url" value="<%= game?.banner_image_url || '' %>">
      <label class="form-label mt-3">Upload Banner</label>
      <input class="form-control" type="file" name="banner" accept="image/*">
      <label class="form-label mt-3">Screenshot URLs</label>
      <textarea class="form-control" name="screenshots" rows="4"><%= (game?.screenshots || []).map((shot) => shot.url || shot).join(', ') %></textarea>
      <label class="form-label mt-3">Upload Screenshots</label>
      <input class="form-control" type="file" name="screenshots" accept="image/*" multiple>
      <hr>
      <label class="form-label">Tags</label>
      <div class="tag-checks">
        <% tags.forEach((tag) => { %>
          <label><input type="checkbox" name="tag_ids" value="<%= tag.id %>" <%= selectedTags.includes(tag.id) ? 'checked' : '' %>> <span style="--tag-color:<%= tag.color_hex %>"><%= tag.name %></span></label>
        <% }) %>
      </div>
      <button class="btn btn-primary w-100 mt-4">Save Game</button>
    </aside>
  </div>
</form>

<% if (game) { %>
  <section class="admin-panel mt-4" id="download-links">
    <div class="panel-head">
      <h2>Download Links</h2>
      <span>Multi-link mirrors</span>
    </div>
    <div class="link-manager">
      <% (game.download_links || []).sort((a, b) => (a.sort_order || 0) - (b.sort_order || 0)).forEach((link) => { %>
        <form action="/admin/games/<%= game.id %>/links/<%= link.id %>?_method=PUT" method="post" class="link-row">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <input class="form-control" name="label" value="<%= link.label %>" placeholder="Label">
          <input class="form-control" name="url" value="<%= link.url %>" placeholder="URL">
          <select class="form-select" name="source_type">
            <% ['direct','torrent','external'].forEach((type) => { %>
              <option value="<%= type %>" <%= link.source_type === type ? 'selected' : '' %>><%= type %></option>
            <% }) %>
          </select>
          <input class="form-control" name="file_size_mb" type="number" step="0.01" value="<%= link.file_size_mb || '' %>" placeholder="MB">
          <input class="form-control" name="version" value="<%= link.version || '' %>" placeholder="Version">
          <input class="form-control" name="platform_target" value="<%= link.platform_target || '' %>" placeholder="Platform">
          <input class="form-control" name="sort_order" type="number" value="<%= link.sort_order || 0 %>" placeholder="Order">
          <label class="form-check"><input class="form-check-input" type="checkbox" name="is_active" <%= link.is_active ? 'checked' : '' %>> Active</label>
          <button class="btn btn-outline-primary btn-sm">Save</button>
          <button form="delete-link-<%= link.id %>" class="btn btn-outline-danger btn-sm" data-confirm="Delete this download link?">Delete</button>
        </form>
        <form id="delete-link-<%= link.id %>" action="/admin/games/<%= game.id %>/links/<%= link.id %>?_method=DELETE" method="post">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
        </form>
      <% }) %>
    </div>
    <form action="/admin/games/<%= game.id %>/links" method="post" class="link-row new-link mt-3">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">
      <input class="form-control" name="label" placeholder="Mirror 1 - Archive.org" required>
      <input class="form-control" name="url" placeholder="https://..." required>
      <select class="form-select" name="source_type">
        <option value="direct">direct</option>
        <option value="torrent">torrent</option>
        <option value="external" selected>external</option>
      </select>
      <input class="form-control" name="file_size_mb" type="number" step="0.01" placeholder="MB">
      <input class="form-control" name="version" placeholder="Version">
      <input class="form-control" name="platform_target" placeholder="Platform">
      <input class="form-control" name="sort_order" type="number" value="0">
      <label class="form-check"><input class="form-check-input" type="checkbox" name="is_active" checked> Active</label>
      <button class="btn btn-primary btn-sm">Add Link</button>
    </form>
  </section>
<% } %>
