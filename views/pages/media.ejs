<section class="page-header media-header">
  <div class="container">
    <span class="eyebrow">Media archive</span>
    <h1>Movies & Shows</h1>
  </div>
</section>

<section class="container py-4">
  <form class="filter-panel" action="/media" method="get">
    <div class="row g-3 align-items-end">
      <div class="col-md-4">
        <label class="form-label">Search</label>
        <input class="form-control" name="q" value="<%= query.q || '' %>" placeholder="Search local media">
      </div>
      <div class="col-md-2">
        <label class="form-label">Type</label>
        <select class="form-select" name="type">
          <option value="">Movies & shows</option>
          <option value="movie" <%= query.type === 'movie' ? 'selected' : '' %>>Movies</option>
          <option value="show" <%= query.type === 'show' ? 'selected' : '' %>>Shows</option>
        </select>
      </div>
      <div class="col-md-3">
        <label class="form-label">Genre</label>
        <select class="form-select" name="genre">
          <option value="">Any genre</option>
          <% genres.forEach((genre) => { %>
            <option value="<%= genre %>" <%= query.genre === genre ? 'selected' : '' %>><%= genre %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">Sort</label>
        <select class="form-select" name="sort">
          <option value="newest" <%= query.sort === 'newest' || !query.sort ? 'selected' : '' %>>Newest</option>
          <option value="downloads" <%= query.sort === 'downloads' ? 'selected' : '' %>>Most downloaded</option>
          <option value="az" <%= query.sort === 'az' ? 'selected' : '' %>>A-Z</option>
        </select>
      </div>
      <div class="col-md-1 d-grid">
        <button class="btn btn-cyan"><i class="bi bi-funnel"></i></button>
      </div>
      <div class="col-12 d-flex flex-wrap gap-2">
        <a class="tag-chip" href="/media">All</a>
        <a class="tag-chip" href="/media?type=movie">Movies</a>
        <a class="tag-chip" href="/media?type=show">Shows</a>
        <% genres.slice(0, 10).forEach((genre) => { %>
          <a class="tag-chip" href="/media?genre=<%= encodeURIComponent(genre) %>"><%= genre %></a>
        <% }) %>
      </div>
    </div>
  </form>
</section>

<section class="container pb-5">
  <div class="section-heading">
    <h2>Latest Media</h2>
    <span><%= Number(total || 0).toLocaleString() %> titles</span>
  </div>
  <% if (items.length) { %>
    <div class="game-grid">
      <% items.forEach((item) => { %>
        <%- include('../partials/media-card', { item }) %>
      <% }) %>
    </div>
    <div class="pagination-row">
      <% if (page > 1) { %><a class="btn btn-outline-info" href="/media?<%= new URLSearchParams({ ...query, page: page - 1 }).toString() %>">Previous</a><% } %>
      <span>Page <%= page %> of <%= totalPages %></span>
      <% if (page < totalPages) { %><a class="btn btn-cyan" href="/media?<%= new URLSearchParams({ ...query, page: page + 1 }).toString() %>">Next</a><% } %>
    </div>
  <% } else { %>
    <div class="empty-state">
      <h2>No media yet.</h2>
      <p>Import movies and shows from TMDB in the admin panel.</p>
    </div>
  <% } %>
  <p class="tmdb-credit mt-4">Metadata and images provided by TMDB.</p>
</section>
