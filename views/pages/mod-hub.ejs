<section class="game-hero mod-hero" style="--hero-image:url('<%= modGame.banner_image_url || modGame.cover_image_url || '/uploads/placeholder-cover.svg' %>')">
  <div class="container">
    <div class="game-hero-grid">
      <img class="detail-cover" src="<%= modGame.cover_image_url || '/uploads/placeholder-cover.svg' %>" alt="<%= modGame.title %> mods cover">
      <div class="detail-copy">
        <div class="badge-row">
          <% (modGame.categories || []).slice(0, 5).forEach((category) => { %>
            <a class="genre-badge" href="/mods/<%= modGame.slug %>?category=<%= category.slug %>" style="--tag-color:<%= category.color_hex %>"><%= category.name %></a>
          <% }) %>
        </div>
        <span class="eyebrow">Mod hub</span>
        <h1><%= modGame.title %></h1>
        <div class="prose"><%- modGame.description || '<p>Browse community files for this game or mod target.</p>' %></div>
        <div class="detail-stats">
          <span><i class="bi bi-puzzle"></i> <%= Number(total || 0).toLocaleString() %> mods</span>
          <% if (modGame.linked_game) { %>
            <span><i class="bi bi-link-45deg"></i> Linked to <a href="/games/<%= modGame.linked_game.slug %>"><%= modGame.linked_game.title %></a></span>
          <% } %>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="container py-4">
  <form class="filter-panel" action="/mods/<%= modGame.slug %>" method="get">
    <div class="row g-3 align-items-end">
      <div class="col-md-5">
        <label class="form-label">Search This Hub</label>
        <input class="form-control" name="q" value="<%= query.q || '' %>" placeholder="Search <%= modGame.title %> mods">
      </div>
      <div class="col-md-3">
        <label class="form-label">Category</label>
        <select class="form-select" name="category">
          <option value="">Any category</option>
          <% (modGame.categories || []).forEach((category) => { %>
            <option value="<%= category.slug %>" <%= selectedCategory?.slug === category.slug ? 'selected' : '' %>><%= category.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">Sort</label>
        <select class="form-select" name="sort">
          <option value="newest" <%= query.sort === 'newest' || !query.sort ? 'selected' : '' %>>Newest</option>
          <option value="downloads" <%= query.sort === 'downloads' ? 'selected' : '' %>>Most downloaded</option>
          <option value="rating" <%= query.sort === 'rating' ? 'selected' : '' %>>Top rated</option>
          <option value="az" <%= query.sort === 'az' ? 'selected' : '' %>>A-Z</option>
        </select>
      </div>
      <div class="col-md-2 d-grid">
        <button class="btn btn-cyan"><i class="bi bi-funnel"></i> Apply</button>
      </div>
      <div class="col-12 d-flex flex-wrap gap-2">
        <a class="tag-chip" href="/mods/<%= modGame.slug %>">All categories</a>
        <% (modGame.categories || []).forEach((category) => { %>
          <a href="/mods/<%= modGame.slug %>?category=<%= category.slug %>" class="tag-chip" style="--tag-color:<%= category.color_hex %>"><%= category.name %></a>
        <% }) %>
      </div>
    </div>
  </form>
</section>

<section class="container pb-5">
  <div class="section-heading">
    <h2><%= selectedCategory ? selectedCategory.name : 'All Mods' %></h2>
    <span><%= Number(total || 0).toLocaleString() %> files</span>
  </div>
  <% if (mods.length) { %>
    <div class="game-grid">
      <% mods.forEach((mod) => { %>
        <%- include('../partials/mod-card', { mod }) %>
      <% }) %>
    </div>
    <div class="pagination-row">
      <% if (page > 1) { %>
        <a class="btn btn-outline-info" href="/mods/<%= modGame.slug %>?<%= new URLSearchParams({ ...query, page: page - 1 }).toString() %>">Previous</a>
      <% } %>
      <span>Page <%= page %> of <%= totalPages %></span>
      <% if (page < totalPages) { %>
        <a class="btn btn-cyan" href="/mods/<%= modGame.slug %>?<%= new URLSearchParams({ ...query, page: page + 1 }).toString() %>">Next</a>
      <% } %>
    </div>
  <% } else { %>
    <div class="empty-state">
      <h2>No mods in this lane yet.</h2>
      <p>This hub is ready for uploads from the admin panel.</p>
      <a class="btn btn-cyan" href="/mods/<%= modGame.slug %>">Reset filters</a>
    </div>
  <% } %>
</section>
