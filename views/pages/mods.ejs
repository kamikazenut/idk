<section class="page-header mods-header">
  <div class="container">
    <span class="eyebrow">Separate archive</span>
    <h1>Mods</h1>
  </div>
</section>

<section class="container py-4">
  <div class="filter-panel">
    <div class="section-heading">
      <div>
        <h2>Mod Hubs</h2>
      </div>
      <a class="section-link" href="#latest-mods">Latest mods</a>
    </div>
    <% if (modGames.length) { %>
      <div class="mod-hub-grid">
        <% modGames.forEach((hub) => { %>
          <a class="mod-hub-card" href="/mods/<%= hub.slug %>" style="--hub-image:url('<%= hub.banner_image_url || hub.cover_image_url || '/uploads/placeholder-cover.svg' %>')">
            <span><%= Number(hub.mod_count || 0).toLocaleString() %> mods</span>
            <h3><%= hub.title %></h3>
            <p><%- hub.description || 'Browse game-specific community files.' %></p>
            <div class="badge-row">
              <% (hub.categories || []).slice(0, 4).forEach((category) => { %>
                <b style="--tag-color:<%= category.color_hex %>"><%= category.name %></b>
              <% }) %>
            </div>
          </a>
        <% }) %>
      </div>
    <% } else { %>
      <div class="empty-state compact">
        <h2>No mod hubs yet.</h2>
        <p>Add hubs like Minecraft, GTA V, Garry's Mod, or any standalone mod target from the admin panel.</p>
      </div>
    <% } %>
  </div>
</section>

<section class="container pb-5" id="latest-mods">
  <form class="filter-panel mb-4" action="/mods" method="get">
    <div class="row g-3 align-items-end">
      <div class="col-md-5">
        <label class="form-label">Search Mods</label>
        <input class="form-control" name="q" value="<%= query.q || '' %>" placeholder="Search mod title, summary, description, or author">
      </div>
      <div class="col-md-3">
        <label class="form-label">Category</label>
        <select class="form-select" name="category">
          <option value="">Any category</option>
          <% categories.forEach((category) => { %>
            <option value="<%= category.slug %>" <%= selectedCategory?.slug === category.slug ? 'selected' : '' %>><%= category.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-2">
        <label class="form-label">Sort</label>
        <select class="form-select" name="sort">
          <option value="newest" <%= query.sort === 'newest' || !query.sort ? 'selected' : '' %>>Newest</option>
          <option value="downloads" <%= query.sort === 'downloads' ? 'selected' : '' %>>Most downloaded</option>
          <option value="rating" <%= query.sort === 'rating' ? 'selected' : '' %>>Top rated</option>
          <option value="az" <%= query.sort === 'az' ? 'selected' : '' %>>A-Z</option>
        </select>
      </div>
      <div class="col-md-2 d-grid">
        <button class="btn btn-cyan"><i class="bi bi-funnel"></i> Filter</button>
      </div>
      <div class="col-12 d-flex flex-wrap gap-2">
        <a class="tag-chip" href="/mods">All mods</a>
        <% categories.slice(0, 10).forEach((category) => { %>
          <a href="/mods?category=<%= category.slug %>" class="tag-chip" style="--tag-color:<%= category.color_hex %>"><%= category.name %></a>
        <% }) %>
      </div>
    </div>
  </form>

  <div class="section-heading">
    <h2>Latest Mods</h2>
    <span><%= Number(latestMods.total || 0).toLocaleString() %> files</span>
  </div>
  <% if (latestMods.mods.length) { %>
    <div class="game-grid">
      <% latestMods.mods.forEach((mod) => { %>
        <%- include('../partials/mod-card', { mod }) %>
      <% }) %>
    </div>
    <div class="pagination-row">
      <% if (latestMods.page > 1) { %>
        <a class="btn btn-outline-info" href="/mods?<%= new URLSearchParams({ ...query, page: latestMods.page - 1 }).toString() %>">Previous</a>
      <% } %>
      <span>Page <%= latestMods.page %> of <%= latestMods.totalPages %></span>
      <% if (latestMods.page < latestMods.totalPages) { %>
        <a class="btn btn-cyan" href="/mods?<%= new URLSearchParams({ ...query, page: latestMods.page + 1 }).toString() %>">Next</a>
      <% } %>
    </div>
  <% } else { %>
    <div class="empty-state">
      <h2>No mods match yet.</h2>
      <p>Try another category or add published mods from the admin panel.</p>
    </div>
  <% } %>
</section>
